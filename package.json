{
    "name": "legacycommunitylauncher",
    "version": "0.1.0",
    "description": "Multi-platform launcher for Minecraft Legacy Console Edition forks.",
    "keywords": [
        "Minecraft",
        "LCE",
        "Minecraft",
        "Launcher",
        "Legacy",
        "Legacy",
        "Launcher"
    ],
    "homepage": "https://git.huckle.dev/TheHuckle/LegacyCommunityLauncher",
    "repository": {
        "type": "git",
        "url": "https://git.huckle.dev/TheHuckle/LegacyCommunityLauncher.git"
    },
    "license": "GPL-3.0-only",
    "author": "TheHuckle",
    "contributors": [
        {
            "name": "TheHuckle",
            "email": "crazyh.dev@gmail.com",
            "url": "https://huckle.dev/"
        }
    ],
    "private": true,
    "scripts": {
        "dev": "WEBKIT_DISABLE_COMPOSITING_MODE=1 neu run",
        "build-mac": "sh ./build-scripts/build-mac.sh",
        "build-linux": "sh ./build-scripts/build-linux.sh",
        "build-win": "sh ./build-scripts/build-win.sh",
        "setup": "npm i && neu update"
    },
    "build": {
        "appId": "dev.huckle.legacycommunitylauncher",
        "productName": "LC Launcher",
        "files": [
            "src/**/*",
            "index.js",
            "package.json"
        ],
        "mac": {
            "target": [
                "dmg"
            ],
            "icon": "assets/icon.icns",
            "minimumSystemVersion": "10.13.0"
        },
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.png"
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "icon": "assets/icon.png"
        }
    },
    "dependencies": {
        "@neutralinojs/neu": "^11.6.0"
    }
}
